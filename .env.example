# Shipmozo Dev Helper & Execution Pipeline Configuration

# 1. Postman Integration (API Testing)
POSTMAN_API_KEY=
POSTMAN_COLLECTION_ID=
POSTMAN_ENVIRONMENT_ID=
POSTMAN_WORKSPACE_ID=

# 2. Panel Login Credentials (for Playwright E2E UI tests)
SHIPMOZO_EMAIL=
SHIPMOZO_PASSWORD=

# 3. AI Providers for Automated Self-Healing (MCP agent)
# Options: openai, azure-openai, claude, gemini, openrouter
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# 4. Cloud Storage for failure screenshots & reports
IMAGE_STORAGE=local
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_UPLOAD_PRESET=

# 5. Local server settings
PORT=3000
HOST=0.0.0.0
